# Environment (dev/development or prod/production)
ENVIRONMENT=production

# Service port
SERVER_PORT=8080

# Admin API secret (required) — set a strong random value in production
ADMIN_SECRET=change_me_in_production

# Database (choose one)
DATABASE_URL=sqlite://data/api_transit.db
# DATABASE_URL=postgresql://user:password@localhost:5432/api_transit
# DATABASE_URL=mysql://user:password@localhost:3306/api_transit

# Health check interval in seconds (default: 1800 = 30 minutes)
HEALTH_CHECK_INTERVAL=1800

# Log level (trace|debug|info|warn|error)
RUST_LOG=info

# Frontend static files directory (optional, default: ./frontend/dist)
FRONTEND_DIST=./frontend/dist
